# PaulAgentBot — Environment Variables (Docker Compose / Production)
# ──────────────────────────────────────────────────────────────────────────────
# Quick start for Docker:
#   cp .env.docker.example .env
#   Fill in all [REQUIRED] values below, then:
#   docker-compose up -d
#
# For local development (pnpm dev):
#   cp .env.example .env
#
# Values marked [SET BY COMPOSE] are overridden in docker-compose.yml and
# don't need to be changed — listed here for documentation only.
#
# NEVER commit .env to version control — it contains secrets.
# ──────────────────────────────────────────────────────────────────────────────


# ── DOCKER IMAGE ──────────────────────────────────────────────────────────────
# [REQUIRED] The image both paulagentbot and paulagentbot-worker containers run.
#
# Build locally:
#   docker build -t paulagentbot:latest .
#   → set: PAULAGENTBOT_IMAGE=paulagentbot:latest
#
# From GitHub Actions / ECR:
#   → set: PAULAGENTBOT_IMAGE=123456789.dkr.ecr.us-east-1.amazonaws.com/paulagentbot:latest
PAULAGENTBOT_IMAGE=

# [REQUIRED] Domain for the Caddy reverse proxy.
# Caddy auto-provisions a Let's Encrypt TLS cert for this domain.
# DNS A record must point to this server's IP before running compose.
# Example: paulagentbot.yourdomain.com
PAULAGENTBOT_DOMAIN=


# ── DATABASE ──────────────────────────────────────────────────────────────────
# [SET BY COMPOSE] docker-compose.yml overrides this to file:/data/paulagentbot.db
# (bind-mounted on the host for persistence across container recreations).
# Only change if switching to PostgreSQL.
DATABASE_URL=file:./dev.db

# [OPTIONAL] "sqlite" (default) or "postgresql".
# DB_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@host:5432/paulagentbot


# ── REDIS ─────────────────────────────────────────────────────────────────────
# [SET BY COMPOSE] docker-compose.yml overrides this to redis://redis:6379
# (the redis service inside the compose network).
REDIS_URL=redis://redis:6379


# ── AUTH ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Signs and encrypts session cookies.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# [REQUIRED] Your production domain (must match PAULAGENTBOT_DOMAIN).
# Format: https://yourdomain.com  (no trailing slash)
NEXTAUTH_URL=https://yourdomain.com

# [REQUIRED] AES-256 key for encrypting tokens/API keys stored in the DB.
# Generate: openssl rand -hex 32  (must be exactly 64 hex characters)
ENCRYPTION_KEY=

# [REQUIRED] Your GitHub username. Grants admin on first login before OAuth
# is configured. Case-sensitive — must match exactly.
BOOTSTRAP_ADMIN=


# ── GITHUB OAUTH (dashboard login) ────────────────────────────────────────────
# [REQUIRED] Create an OAuth App (NOT a GitHub App) at:
#   https://github.com/settings/developers → "New OAuth App"
#
# Set callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=


# ── GITHUB APP (repo integration + webhooks) ──────────────────────────────────
# [REQUIRED] Webhook URL: https://yourdomain.com/api/webhooks/github
# Full setup guide: README → "GitHub App Setup"

# Numeric App ID from the app's settings page.
GITHUB_APP_ID=

# Full contents of the .pem private key file (include BEGIN/END lines).
# To convert multi-line to single-line for .env:
#   awk 'NF {ORS="\\n"; print}' private-key.pem
GITHUB_APP_PRIVATE_KEY=

# Random secret set when creating the app — verifies webhook signatures.
# Generate: openssl rand -hex 20
GITHUB_APP_WEBHOOK_SECRET=

# Bot's GitHub username, e.g. yourappname[bot]
GITHUB_APP_BOT_USERNAME=


# ── CLAUDE CODE ───────────────────────────────────────────────────────────────
# [REQUIRED] Path to the ~/.claude directory on the HOST machine.
# docker-compose bind-mounts this into the container at /root/.claude so the
# agent can authenticate with Claude Code CLI.
#
# On EC2 (root):   /root/.claude
# On EC2 (ubuntu): /home/ubuntu/.claude
# On macOS:        /Users/yourname/.claude
#
# First-time setup on a fresh server:
#   ssh into the server, then run: claude
#   Log in when prompted. Credentials are saved to this directory.
#   Then set this var to that directory path.
CLAUDE_AUTH_DIR=/root/.claude


# ── WORKSPACE ─────────────────────────────────────────────────────────────────
# [SET BY COMPOSE] docker-compose.yml overrides this to /data/workspaces
# (bind-mounted on the host for persistence).
# Before first run, create the directory: mkdir -p /data/workspaces
WORKSPACE_BASE=/data/workspaces


# ── TELEGRAM (optional) ───────────────────────────────────────────────────────
# [OPTIONAL] Bot starts automatically when set. Leave blank to disable.
# Get token: message @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=


# ── SLACK (optional) ──────────────────────────────────────────────────────────
# [OPTIONAL] Both vars required to enable Slack.
# SLACK_BOT_TOKEN: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET: https://api.slack.com/apps → Basic Information → App Credentials
SLACK_SIGNING_SECRET=


# ── EMAIL (optional) ──────────────────────────────────────────────────────────
# [OPTIONAL] Both vars required to enable email via SendGrid Inbound Parse.
# SENDGRID_API_KEY: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Sender address for outbound emails — must be verified in SendGrid.
EMAIL_FROM_ADDRESS=


# ── LOGGING ───────────────────────────────────────────────────────────────────
# Stdout is always active. LOG_FILE=true also writes to logs/worker-YYYY-MM-DD.log
LOG_FILE=false
# Minimum level: debug | info | warn | error
LOG_LEVEL=info
# Days to keep log files before deletion
LOG_MAX_DAYS=7
