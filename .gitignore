# ── Environment & secrets ────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# Private keys — NEVER commit
*.pem
*.key
*.p12
*.pfx

# ── Dependencies ─────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
# This is a pnpm project — only pnpm-lock.yaml should be committed
package-lock.json
yarn.lock

# ── Next.js ──────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Database ──────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
prisma/dev.db
prisma/*.db

# ── Testing ───────────────────────────────────────────────────────
coverage/
.vitest-cache/

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Build artifacts ───────────────────────────────────────────────
tsconfig.tsbuildinfo

# ── Claude Code agent skills (workspace-local, not part of project) ───
.agents/
.claude/

# ── Terraform ────────────────────────────────────────────────────
# Real variable values (may contain tokens, IPs, secrets)
terraform/terraform.tfvars
terraform/terraform.tfvars.json
# State files contain ALL resource details including sensitive values in plaintext
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform/
terraform/crash.log
# Override files (local developer overrides)
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json

# ── TypeScript ────────────────────────────────────────────────────
tsconfig.tsbuildinfo
*.tsbuildinfo

# ── Claude Code local state ───────────────────────────────────────
.atl/

# ── Misc ──────────────────────────────────────────────────────────
.turbo/
.vercel/
.cache/
