# PaulAgentBot — Terraform Variables
# Copy to terraform.tfvars and fill in your values:
#   cp terraform/terraform.tfvars.example terraform/terraform.tfvars
#
# Never commit terraform.tfvars to version control.

# ── AWS ───────────────────────────────────────────────────────────────────────
aws_region  = "us-east-1"
aws_profile = "default"   # AWS CLI profile to use

# ── Instance ──────────────────────────────────────────────────────────────────
instance_type    = "t3.small"   # t3.micro for lighter use, t3.medium for heavier
root_volume_size = 20           # GB — OS + Docker images
data_volume_size = 20           # GB — SQLite DB + workspaces + Caddy TLS certs

# Path to your SSH public key (used to create EC2 key pair)
public_key_path = "~/.ssh/id_ed25519.pub"

# Restrict to your IP for security: "x.x.x.x/32"
allowed_ssh_cidr = "0.0.0.0/0"

# ── Domain ────────────────────────────────────────────────────────────────────
# Point this domain's A record to the elastic_ip output after first apply
domain_name = "paulagentbot.yourdomain.com"

# ── GitHub ────────────────────────────────────────────────────────────────────
# Your GitHub repo — required for the OIDC deploy role (owner/repo format)
github_repo = "yourusername/paulagentbot"

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Automatically stops/starts EC2 to save money. Adjust to your timezone and schedule.
scheduler_stop_cron  = "cron(30 22 * * ? *)"    # Stop at 22:30 every day
scheduler_start_cron = "cron(0 7 ? * MON-SAT *)" # Start at 07:00 Mon–Sat
scheduler_timezone   = "America/Bogota"           # https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

# ── Scheduler Telegram notifications (optional) ───────────────────────────────
# Infrastructure alerts: notifies when EC2 powers on or off.
# Leave empty to disable. These are separate from PaulAgentBot's in-app notifications.
telegram_bot_token = ""   # same bot token as in .env
telegram_chat_id   = ""   # your personal Telegram chat ID
