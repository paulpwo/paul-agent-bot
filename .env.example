# PaulAgentBot — Environment Variables (Local Development)
# ──────────────────────────────────────────────────────────────────────────────
# Quick start:
#   cp .env.example .env
#   Fill in the [REQUIRED] values below, then run: pnpm dev
#
# For Docker Compose (production):
#   cp .env.docker.example .env
#
# NEVER commit .env to version control — it contains secrets.
# ──────────────────────────────────────────────────────────────────────────────


# ── DATABASE ──────────────────────────────────────────────────────────────────
# [REQUIRED]
# SQLite: file is created automatically on first migration — no setup needed.
DATABASE_URL=file:./dev.db

# [OPTIONAL] "sqlite" (default) or "postgresql".
# Only change if switching to PostgreSQL.
# DB_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/paulagentbot


# ── REDIS ─────────────────────────────────────────────────────────────────────
# [REQUIRED] BullMQ task queue.
#
# Start Redis locally (pick one):
#   docker run -d -p 6379:6379 --name redis redis:7-alpine
#   brew install redis && brew services start redis
#
# Verify: redis-cli ping  →  should print PONG
REDIS_URL=redis://localhost:6379


# ── AUTH ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Signs and encrypts NextAuth session cookies.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# [REQUIRED] Public URL of the app — used for OAuth redirects.
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# [REQUIRED] AES-256 key for encrypting tokens and API keys stored in the DB.
# Generate: openssl rand -hex 32
# Must be exactly 64 hex characters (= 32 bytes).
ENCRYPTION_KEY=

# [REQUIRED] Your GitHub username. Grants admin access on the very first login
# before GitHub OAuth is fully configured. Case-sensitive — must match exactly.
BOOTSTRAP_ADMIN=


# ── GITHUB OAUTH (dashboard login) ────────────────────────────────────────────
# [REQUIRED] The dashboard sign-in uses GitHub OAuth.
#
# Create an OAuth App (NOT a GitHub App) at:
#   https://github.com/settings/developers → "New OAuth App"
#
# For local dev, set:
#   Homepage URL:              http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
#
# For production, replace localhost:3000 with your domain.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=


# ── GITHUB APP (repo integration + webhooks) ──────────────────────────────────
# [REQUIRED] Receives webhook events and acts on repositories.
# Full setup guide: README → "GitHub App Setup"
#
# Webhook URL:
#   Local dev: ngrok required → https://abc.ngrok.io/api/webhooks/github
#   Production: https://yourdomain.com/api/webhooks/github
#
# Required permissions: Contents (R/W), Issues (R/W), Pull requests (R/W), Metadata (R)
# Required events: issue_comment, issues, pull_request, pull_request_review_comment

# Numeric App ID shown on the app's settings page.
GITHUB_APP_ID=

# Full contents of the downloaded .pem private key file.
# Include the -----BEGIN RSA PRIVATE KEY----- and -----END----- lines.
# To convert multi-line to single-line for .env:
#   awk 'NF {ORS="\\n"; print}' private-key.pem
GITHUB_APP_PRIVATE_KEY=

# Random secret set when creating the app — verifies webhook signatures.
# Generate: openssl rand -hex 20
GITHUB_APP_WEBHOOK_SECRET=

# Bot's GitHub username shown on the app settings page.
# Format: yourappname[bot]
GITHUB_APP_BOT_USERNAME=


# ── CLAUDE CODE ───────────────────────────────────────────────────────────────
# LOCAL DEV: Leave both blank.
#   The app runs `claude` directly from your host PATH. Your ~/.claude
#   credentials are read automatically from macOS Keychain — no config needed.
#
# DOCKER / EC2 (required for production):
#   Two variables must be set in /home/ubuntu/paulagentbot/.env on the server:
#
#   1. CLAUDE_CODE_OAUTH_TOKEN — long-lived OAuth token used by the claude CLI
#      subprocess inside each Docker container (runs with HOME=/tmp, no keychain).
#
#      How to get it:
#        a. On your local machine (already logged in to claude):
#             cat ~/.claude/.credentials.json
#             # Copy the value of "claudeAiOauthToken" (or "oauth_token")
#        b. OR run: claude auth token   (if supported by your claude version)
#        c. OR run: cat ~/.claude/settings.json | python3 -m json.tool | grep -i token
#
#      The token looks like: sk-ant-ocp01-...  or  ey...  (long string)
#      It is long-lived (does not expire daily like GitHub App tokens).
#
#   2. CLAUDE_AUTH_DIR — path on the HOST to the ~/.claude directory.
#      Bind-mounted into containers at /root/.claude (read-only) so the
#      main Next.js process can access Claude settings and session state.
#      On EC2: /root/.claude  or  /home/ubuntu/.claude
#
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_AUTH_DIR=


# ── WORKSPACE ─────────────────────────────────────────────────────────────────
# [OPTIONAL] Directory where repos are cloned.
# Defaults to ./workspaces (relative to project root) when not set.
# Production: use a persistent volume path, e.g. /data/workspaces
# WORKSPACE_BASE=./workspaces


# ── TELEGRAM (optional) ───────────────────────────────────────────────────────
# [OPTIONAL] Bot starts automatically when this is set. Leave blank to disable.
#
# Get token:
#   1. Message @BotFather on Telegram
#   2. Send /newbot and follow the prompts
#   3. Copy the token (format: 1234567890:ABCdef...)
TELEGRAM_BOT_TOKEN=


# ── OPENAI (optional) ─────────────────────────────────────────────────────────
# [OPTIONAL] Required for voice note responses (TTS).
# When user asks the bot to respond with a voice note, the result is converted
# to speech using OpenAI TTS (tts-1 model, nova voice).
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── SLACK (optional) ──────────────────────────────────────────────────────────
# [OPTIONAL] Enables the Slack channel bridge.
# Both vars required if you want Slack — one without the other won't work.
#
# SLACK_BOT_TOKEN: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET: https://api.slack.com/apps → Basic Information → App Credentials
SLACK_SIGNING_SECRET=


# ── EMAIL (optional) ──────────────────────────────────────────────────────────
# [OPTIONAL] Enables inbound email tasks via SendGrid Inbound Parse.
# Both vars required if you want email — one without the other won't work.
#
# SENDGRID_API_KEY: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Sender address shown in outbound emails — must be verified in SendGrid.
EMAIL_FROM_ADDRESS=


# ── LOGGING ───────────────────────────────────────────────────────────────────
# [OPTIONAL] Stdout logging is always active. Set LOG_FILE=true to also write
# to files under logs/worker-YYYY-MM-DD.log
LOG_FILE=false
# Minimum level: debug | info | warn | error
LOG_LEVEL=info
# Days to keep log files before auto-deletion
LOG_MAX_DAYS=7


# ── DOCKER / PRODUCTION ONLY ──────────────────────────────────────────────────
# These are only needed when running via docker-compose. Leave blank for local dev.

# Docker image to run.
# After building: docker build -t paulagentbot . → set to paulagentbot:latest
# From ECR:       123456789.dkr.ecr.us-east-1.amazonaws.com/paulagentbot:latest
# PAULAGENTBOT_IMAGE=

# Domain for the Caddy reverse proxy — Caddy handles HTTPS automatically.
# Example: paulagentbot.yourdomain.com
# PAULAGENTBOT_DOMAIN=
