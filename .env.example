# PaulAgentBot — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Never commit .env to version control.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Local dev: http://localhost:3000 | Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Encryption key for settings stored in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Your GitHub username — required for first login before OAuth is configured
BOOTSTRAP_ADMIN=your-github-username

# ── GitHub OAuth (for dashboard login) ────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create at https://github.com/settings/apps
GITHUB_APP_ID=
# Paste the full PEM private key (include -----BEGIN/END----- lines)
# Or store as single line with \n between lines
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Username of the bot account (e.g. mybot[bot])
GITHUB_APP_BOT_USERNAME=

# ── Workers ───────────────────────────────────────────────────────────────────
# Set to "true" when running a dedicated worker process (pnpm worker).
# Prevents the Next.js dev server from also starting workers + Telegram bot,
# which would cause a 409 conflict with Telegram's getUpdates API.
WORKER_ONLY=true

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379 | Docker: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite — no extra setup needed):
DATABASE_URL=file:./dev.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/paulagentbot

# ── Claude Code ───────────────────────────────────────────────────────────────
# Path to your ~/.claude directory on the HOST machine.
# Local dev (macOS): /Users/yourname/.claude
# EC2 (Ubuntu):      /home/ubuntu/.claude
CLAUDE_AUTH_DIR=/Users/yourname/.claude

# ── Docker only (not needed for local dev) ────────────────────────────────────
# PAULAGENTBOT_IMAGE=
# PAULAGENTBOT_DOMAIN=paulagentbot.yourdomain.com
# CLAUDE_CODE_ALLOW_ROOT_EXECUTION=1
