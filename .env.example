# PaulAgentBot — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Never commit .env to version control.

# ── Docker image ──────────────────────────────────────────────────────────────
# Set by deploy.sh automatically. Override manually if needed.
PAULAGENTBOT_IMAGE=

# ── Domain ────────────────────────────────────────────────────────────────────
PAULAGENTBOT_DOMAIN=paulagentbot.yourdomain.com

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://paulagentbot.yourdomain.com

# Encryption key for settings stored in the database
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create at https://github.com/settings/apps
GITHUB_APP_ID=
# Paste the full PEM private key (include -----BEGIN/END----- lines)
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Username of the bot account (e.g. mybot[bot])
GITHUB_APP_BOT_USERNAME=

# ── GitHub OAuth (for dashboard login) ────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ── Redis ─────────────────────────────────────────────────────────────────────
# When using docker-compose, leave as-is
REDIS_URL=redis://redis:6379

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path inside the container (bind-mounted from /data/paulagentbot.db on the host)
DATABASE_URL=file:/data/paulagentbot.db

# ── Claude Code auth directory ────────────────────────────────────────────────
# Path to your ~/.claude directory on the HOST machine.
# Bind-mounted read-only into containers so the agent can authenticate.
# On EC2 (Ubuntu):  /home/ubuntu/.claude
# On macOS (local): /Users/yourname/.claude
CLAUDE_AUTH_DIR=/home/ubuntu/.claude
